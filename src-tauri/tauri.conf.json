{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JoyCon2 to Key",
  "version": "0.1.3",
  "identifier": "com.pboaa.joycon2-to-key",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "JoyCon2 to Key",
        "width": 960,
        "height": 660,
        "minWidth": 860,
        "minHeight": 600,
        "resizable": true,
        "maximizable": true,
        "center": true,
        "decorations": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; frame-src 'none'",
      "devCsp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost ws://localhost:1420 http://localhost:1420; object-src 'none'; base-uri 'self'; frame-src 'none'"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/pboaa/joycon2-to-key/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQzRDY2QzJCQjkyQzlEOTEKUldTUm5TeTVLMnpXMCtIVGRWSkk4R053b0VrQ2QxdG9Ca1FNa0pTUFMzSU1vcCs2TFF2bzFKay8K"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
